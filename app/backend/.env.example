# Copy to .env and fill in. Backend reads via python-dotenv on startup.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=

# Optional: which Claude model to use for chat. Defaults to the latest Sonnet.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Path to the OpenTofu root config the UI inspects. Relative to repo root.
TOFU_ROOT=live/dev

# Where the repo root lives on disk. Defaults to two levels up from this file.
# Set explicitly if you run uvicorn from somewhere unexpected.
# REPO_ROOT=/Users/you/DevEx
