# Local state file for the blueprint workspace (backend = local).
# Promote to the S3 backend once the workspace stabilizes.
terraform.tfstate
terraform.tfstate.backup
.terraform/
.terraform.lock.hcl

# Canvas-generated artifacts: each resource the Blueprint UI saves
# lives as `bp.<type>.<name>.tf` at the workspace root (root-only so
# OpenTofu's loader sees it — subdirs are ignored). Canvas positions
# are stored in `_layout.json`. These are per-session/experiment, not
# repo-source; promote a resource to the canonical layout (`main.tf`
# or a module) when ready and the canvas writes become safe to delete.
bp.*.tf
_layout.json
# Discovery manifest (agent-written) + the component hierarchy mapping.
# Per-session/experiment runtime state, not repo-source.
_discovered.json
_hierarchy.json
# Legacy pre-flat layout (migrated to bp.*.tf on first list).
resources/
