# Source this to point all tofu/aws commands at the local Moto server:
#   source dev.local.env
# Open a fresh shell or `unset` these vars to target real AWS again.
#
# Despite the variable name, this works for any local AWS emulator (Moto today,
# LocalStack later if we add an auth token). The var name stays generic so HCL
# doesn't need to change.

export TF_VAR_use_localstack=true

# Moto accepts any non-empty creds; "test" is the project convention.
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_DEFAULT_REGION=us-east-1

# Endpoint redirects (consumed by AWS SDK and OpenTofu's state-encryption KMS client).
export AWS_ENDPOINT_URL=http://localhost:4566
export AWS_ENDPOINT_URL_S3=http://localhost:4566
export AWS_ENDPOINT_URL_DYNAMODB=http://localhost:4566
export AWS_ENDPOINT_URL_KMS=http://localhost:4566
export AWS_ENDPOINT_URL_STS=http://localhost:4566
export AWS_ENDPOINT_URL_IAM=http://localhost:4566
export AWS_ENDPOINT_URL_EC2=http://localhost:4566
